# Copy this file to .env.local for local development (gitignored).
# For production, set these in the Cloudflare Pages dashboard under
# Settings → Environment Variables.

# Public-side (exposed to browser; protected by Supabase RLS).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key-here

# Only used by tools/migrate-from-sheets.mjs — never expose this client-side.
# Generate at Supabase dashboard → Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key-here
